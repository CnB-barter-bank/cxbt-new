# Приватный ключ деплоера (НЕ КОММИТИТЬ В GIT!)
DEPLOYER_PRIVATE_KEY=0x...

# API ключ для Basescan (для верификации контрактов)
# Получите на https://basescan.org/myapikey
# Используется единый API ключ для всех сетей (Etherscan V2 API)
BASESCAN_API_KEY=

# RPC URL для сети (например, для Base, Polygon, Ethereum, etc.)
# Примеры:
# - Base Mainnet: https://mainnet.base.org или https://base.publicnode.com
# - Base Sepolia Testnet: https://sepolia.base.org
# - Polygon Mainnet: https://polygon-rpc.com
# - Polygon Amoy Testnet: https://rpc-amoy.polygon.technology
# - Ethereum Mainnet: https://eth.llamarpc.com
# - Sepolia Testnet: https://rpc.sepolia.org
RPC_URL=https://mainnet.base.org

# Адрес платежного контракта (PAID токен)
PAID_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Параметры токена
TOKEN_NAME=CXBT
TOKEN_SYMBOL=CXBT
TOKEN_DECIMALS=6

# Начальное количество токенов (в единицах токена, не в wei)
INITIAL_SUPPLY=10000000

# Процент разблокировки (в базисных пунктах: 10000 = 100%)
UNLOCK_PERCENTAGE=1000

# Адрес существующего Diamond для редеплоя (опционально)
DIAMOND_ADDRESS=
