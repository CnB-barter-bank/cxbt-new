{
  "name": "cxbt-frontend",
  "version": "0.0.1",
  "description": "CXBT Frontend MVP",
  "productName": "CXBT",
  "author": "",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "lint": "eslint . --ext .vue,.js,.ts",
    "lint:fix": "eslint . --ext .vue,.js,.ts --fix",
    "format": "prettier --write \"src/**/*.{vue,js,ts,scss,css,json}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest --run",
    "test:ui": "vitest --run --ui",
    "test:coverage": "vitest --run --coverage"
  },
  "devDependencies": {
    "@quasar/app-vite": "^2.5.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/devtools": "^8.1.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^18 || ^20 || ^21",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "@tanstack/vue-query": "^5.95.2",
    "@wagmi/connectors": "^8.0.0",
    "@wagmi/core": "^3.4.1",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "@web3modal/wagmi": "^5.1.11",
    "pinia": "^3.0.4",
    "porto": "^0.2.37",
    "quasar": "^2.19.2",
    "viem": "^2.47.6",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4"
  }
}
