{
  "name": "cxbt",
  "version": "1.0.0",
  "description": "CXBT - Vue + Quasar Web3 Application",
  "productName": "CXBT",
  "author": "CXB Team",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "format": "prettier --write \"**/*.{js,vue,ts,css,scss,md,json}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,vue,ts,css,scss,md,json}\" --ignore-path .prettierignore",
    "type-check": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "audit:fix:force": "npm audit fix --force",
    "security:check": "node scripts/security-check.js",
    "security:audit": "npm audit --audit-level=high",
    "analyze": "npm run lint && npm run format:check && npm run audit && npm run security:check",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "test:unit": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:unit:watch": "vitest watch",
    "test:unit:coverage": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:coverage:html": "vitest run --coverage --reporter=html",
    "test:coverage:json": "vitest run --coverage --reporter=json",
    "test:coverage:lcov": "vitest run --coverage --reporter=lcov",
    "test:ci": "vitest run --coverage --reporter=lcov --reporter=json"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.11",
    "axios": "^1.6.7",
    "ethers": "^6.11.1",
    "pinia": "^2.1.7",
    "quasar": "^2.14.3",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@quasar/app-vite": "^1.7.3",
    "@quasar/quasar-app-extension-testing-unit-vitest": "^1.2.4",
    "@quasar/vite-plugin": "^1.7.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint-plugin-prettier": "^5.5.5",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-vue": "^9.23.0",
    "happy-dom": "^20.8.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "vite": "^5.1.6",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">= 12.22.1",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
