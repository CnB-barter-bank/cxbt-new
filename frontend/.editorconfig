# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript and Vue files
[*.{js,vue}]
indent_style = space
indent_size = 2
max_line_length = 100

# TypeScript files
[*.ts]
indent_style = space
indent_size = 2
max_line_length = 100

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2
max_line_length = 80

# CSS and SCSS files
[*.{css,scss,less}]
indent_style = space
indent_size = 2

# HTML files
[*.html]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf

# Makefiles
[Makefile]
indent_style = tab

# Package files
[{package,bower}.json]
indent_style = space
indent_size = 2

# Config files
[*.{eslintrc,prettierrc,editorconfig}]
indent_style = space
indent_size = 2
